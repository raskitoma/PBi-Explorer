# --- Cloud ------------------------------------------------------------------
AZURE_CLOUD=commercial
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
M365_REDIRECT_URI=http://localhost:8080/m365/callback

# --- Database ---------------------------------------------------------------
DB_HOST=db
DB_PORT=3306
DB_NAME=m365_audit
DB_USER=m365
DB_PASS=
MARIADB_ROOT_PASSWORD=

# --- Dashboard --------------------------------------------------------------
DASHBOARD_USER=admin
DASHBOARD_PASS_HASH=
APP_SECRET_KEY=
WEB_PORT=8080

# --- OIDC (optional) --------------------------------------------------------
# OIDC_ISSUER_URL=https://login.example.com
# OIDC_CLIENT_ID=
# OIDC_CLIENT_SECRET=
# OIDC_REDIRECT_URI=https://audit.example.com/auth/oidc/callback
# OIDC_REQUIRED_GROUP=audit-admins
# OIDC_USERNAME_CLAIM=preferred_username
LOCAL_LOGIN_ENABLED=true

# --- Ingest tuning ----------------------------------------------------------
# Default OFF — worker pollers no-op until you validate mappings and flip this.
INGEST_ENABLED=false
POLL_INTERVAL_S=300
GRAPH_LOOKBACK_HOURS=24
MGMT_CONTENT_TYPES=Audit.SharePoint,Audit.Exchange,Audit.AzureActiveDirectory,Audit.General

# --- Timezone (also used by host TZ inside container) -----------------------
TZ=UTC

# --- Dev escape hatch (DO NOT set in prod) ----------------------------------
FORCE_INSECURE=false
